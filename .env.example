# =============================================================================
# StockSense — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required)
# Found in: Supabase dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ---------------------------------------------------------------------------
# OpenAI (server-side only — set as Supabase Edge Function secret)
# Used for: GPT-4o Vision (receipt OCR) and text-embedding-3-small (semantic search)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Google Cloud Vision API (server-side only — set as Supabase Edge Function secret)
# Used for: Food label and object detection in fridge/pantry photos
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_VISION_API_KEY=AIza...

# ---------------------------------------------------------------------------
# Firebase (optional — required only for push notifications)
# Android: place google-services.json in android/app/
# iOS: place GoogleService-Info.plist in ios/Runner/
# ---------------------------------------------------------------------------
# FCM_SERVER_KEY is set as a Supabase Edge Function secret, not here
# FCM_SERVER_KEY=

# ---------------------------------------------------------------------------
# Sentry (optional — for error monitoring in production)
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://...@sentry.io/...
